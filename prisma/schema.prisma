generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth Required Tables ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Tables ───

enum UserRole {
  DONOR
  PARTNER
  ADMIN
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  role              UserRole @default(DONOR)
  stripeCustomerId  String?
  mpesaPhone        String?
  createdAt         DateTime @default(now())

  accounts          Account[]
  sessions          Session[]
  projects          Project[]
  donations         Donation[]
  evidenceSubmitted Evidence[]
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  FUNDED
  IN_PROGRESS
  COMPLETED
  FAILED
}

model Project {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  summary        String?
  description    String        @db.Text
  category       String?
  region         String?
  country        String?
  partnerId      String
  status         ProjectStatus @default(DRAFT)
  goalAmount     Decimal       @db.Decimal(12, 2)
  raisedAmount   Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("USD")
  coverImageUrl  String?
  lat            Float?
  lng            Float?
  createdAt      DateTime      @default(now())
  approvedAt     DateTime?
  completedAt    DateTime?

  partner    User        @relation(fields: [partnerId], references: [id])
  milestones Milestone[]
  donations  Donation[]
  stories    Story[]
}

enum MilestoneStatus {
  PENDING
  EVIDENCE_SUBMITTED
  VERIFICATION_IN_PROGRESS
  VERIFIED
  FUNDS_RELEASED
  FAILED
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String
  title          String
  description    String          @db.Text
  amountRequired Decimal         @db.Decimal(12, 2)
  orderIndex     Int
  status         MilestoneStatus @default(PENDING)
  dueDate        DateTime?
  completedAt    DateTime?

  project  Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidence Evidence[]
  stories  Story[]
}

enum HumanReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_INFO
}

model Evidence {
  id                    String             @id @default(cuid())
  milestoneId           String
  submittedBy           String
  photoUrls             String[]
  videoUrl              String?
  gpsLat                Float?
  gpsLng                Float?
  gpsAccuracy           Float?
  description           String             @db.Text
  communityVoiceUrl     String?
  submittedAt           DateTime           @default(now())
  aiVerificationScore   Float?
  aiVerificationResult  Json?
  humanReviewStatus     HumanReviewStatus  @default(PENDING)
  humanReviewerId       String?
  reviewedAt            DateTime?

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  submitter User      @relation(fields: [submittedBy], references: [id])
}

enum ApplicationStatus {
  SUBMITTED
  AI_SCREENED
  HUMAN_REVIEW
  APPROVED
  REJECTED
}

model PartnerApplication {
  id                    String            @id @default(cuid())
  orgName               String
  orgCountry            String
  orgRegistrationNumber String?
  contactName           String
  contactEmail          String
  missionStatement      String            @db.Text
  projectDescription    String            @db.Text
  budgetEstimate        Decimal           @db.Decimal(12, 2)
  supportingDocUrls     String[]
  status                ApplicationStatus @default(SUBMITTED)
  aiScore               Json?
  submittedAt           DateTime          @default(now())
  reviewedAt            DateTime?
  reviewerNotes         String?           @db.Text
}

enum DonationStatus {
  PENDING
  ESCROWED
  RELEASED
  REFUNDED
}

model Donation {
  id                    String         @id @default(cuid())
  donorId               String
  projectId             String
  amount                Decimal        @db.Decimal(12, 2)
  currency              String         @default("USD")
  stripePaymentIntentId String?
  status                DonationStatus @default(PENDING)
  milestoneId           String?
  createdAt             DateTime       @default(now())
  releasedAt            DateTime?

  donor   User    @relation(fields: [donorId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
}

enum WaitlistType {
  DONOR
  PARTNER
  CORPORATE
}

model Waitlist {
  id        String       @id @default(cuid())
  email     String       @unique
  name      String?
  type      WaitlistType @default(DONOR)
  source    String?
  createdAt DateTime     @default(now())
}

model Story {
  id                       String    @id @default(cuid())
  projectId                String
  milestoneId              String?
  rawContent               String?   @db.Text
  translatedContent        Json?
  generatedDonorUpdate     String?   @db.Text
  communityVoiceTranscript String?   @db.Text
  approvedByPartner        Boolean   @default(false)
  publishedAt              DateTime?
  shareCount               Int       @default(0)

  project   Project    @relation(fields: [projectId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])
}
